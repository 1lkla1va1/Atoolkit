# Codex 配置示例 —— 合并进 ~/.codex/config.toml（按你的版本核对键名：codex --help / 文档）
#
# 设计意图：用 Codex 自带的 sandbox + approval 充当"外部硬约束的地板"。
# 模型负责推理；越权发包/危险命令由沙箱兜底，而不是靠模型自觉。

# ── 模型（模型无关：换这一行即可换模型）──────────────────────────
model = "gpt-5.5-codex"          # 也可 o4-mini / 自建 OpenAI 兼容端点的模型名

# ── 审批与沙箱（硬约束地板）──────────────────────────────────────
# 测试要发包取证，需要可写工作区 + 受控网络；但默认禁止危险全权。
approval_policy = "on-failure"    # 失败/越权时才打断问你；可改 "untrusted" 更严
sandbox_mode = "workspace-write"  # 只能写工作目录（证据落 runs/）；不可碰系统其它路径

[sandbox_workspace_write]
# SRC 必须联网发包——但务必把出站收敛到授权目标。
# Codex 沙箱本身不做 host 白名单；host 级白名单放到编排外壳/代理层做（见 codex_adapter.py 注释）。
network_access = true

# ── 自定义模型供应商示例（DeepSeek / Qwen / 本地 vLLM 同一套，体现模型无关）──
# [model_providers.deepseek]
# name = "DeepSeek"
# base_url = "https://api.deepseek.com/v1"
# env_key = "DEEPSEEK_API_KEY"
# 然后把上面的 model 改成该供应商的模型名，并指定 model_provider = "deepseek"

# 注意：
# 1) AGENTS.md 的放置（全局 ~/.codex/AGENTS.md 或项目根 AGENTS.md）决定核心技能文件是否每会话自动注入。
# 2) network_access=true 打开后，host 白名单/危险命令拦截要靠外壳兜（别只依赖模型守规矩）。
