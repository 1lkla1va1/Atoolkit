{
  "id": "idor-multi-identity",
  "title": "多身份 IDOR",
  "description": "覆盖对象级授权、跨账户读取、跨账户修改、角色边界和对象归属校验。",
  "match": {
    "vuln_classes": ["越权/IDOR", "未授权访问"],
    "params": ["id", "uid", "user_id", "order_id", "bug_id", "project_id", "address_id", "owner_id", "account_id"],
    "keywords": ["detail", "profile", "order", "address", "project", "bug", "identity_meta"]
  },
  "dimensions": [
    "对象读取是否绑定当前授权身份",
    "对象修改、删除、审批是否校验对象归属",
    "列表、详情、导出、日志之间是否存在权限差异",
    "不同角色对同一对象的授权边界是否一致"
  ],
  "false_negative_rules": [
    "单身份自测不能证明对象级授权闭合",
    "只测列表不能证明详情、修改、导出闭合",
    "只测不存在对象不能证明他人对象被拒绝"
  ],
  "evidence_required": [
    "owner_identity",
    "peer_identity",
    "object_ownership",
    "access_result"
  ],
  "negative_sufficiency": {
    "min_vectors": 3,
    "min_response_count": 2,
    "required_evidence_types": ["owner_identity", "peer_identity", "object_ownership", "access_result"],
    "min_identities": 2
  },
  "positive_depth_floor": {
    "min_depth": 3,
    "min_vectors": 3,
    "min_roles": 2,
    "min_objects": 2,
    "note": "IDOR/越权：2 角色×2 对象对比证据 + ≥3 独立向量，达 depth_score 3 才许 proof_ready"
  }
}
