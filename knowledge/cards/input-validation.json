{
  "id": "input-validation",
  "title": "输入校验",
  "description": "覆盖搜索、排序、过滤、分页、类型转换、边界值和服务端错误处理。",
  "match": {
    "risk_tags": ["input-validation", "injection", "sqli", "xss"],
    "vuln_classes": [
      "SQLi",
      "XSS",
      "SSRF"
    ],
    "params": [
      "keyword",
      "search",
      "q",
      "sort",
      "orderBy",
      "filter",
      "page",
      "size",
      "type",
      "status",
      "url",
      "path"
    ],
    "keywords": [
      "search",
      "query",
      "filter",
      "sort",
      "orderby",
      "keyword"
    ],
    "secondary_params": [
      "hash",
      "acctid",
      "regid",
      "organization_id",
      "post_type",
      "import_url",
      "callback_url",
      "svg",
      "protocol",
      "filepath",
      "file_path",
      "filepathdownload",
      "redirect_uri",
      "redir",
      "return_url",
      "next",
      "return_to",
      "redirect_to",
      "goto",
      "target",
      "response_type",
      "scope",
      "state"
    ]
  },
  "dimensions": [
    "输入类型、长度、字符类别和枚举范围是否由服务端校验",
    "排序、过滤、分页字段是否使用服务端固定字段集",
    "错误响应是否稳定且不泄露内部实现",
    "同一参数在列表、详情、导出链路中的校验是否一致",
    "接受文本输入并可能持久化的端点是否执行了存储→渲染闭环验证（POST后GET检查探测输入是否被原样渲染）"
  ],
  "false_negative_rules": [
    "只测正常输入不能证明输入校验闭合",
    "只看页面无报错不能证明后端处理稳定",
    "只测一个参数不能覆盖同类入口的校验差异",
    "WAF/关键字拦截不等于漏洞不存在——被拦截只说明探测数据被检测，不说明漏洞不存在，需换编码或绕过方式重试",
    "POST返回空/200不等于安全——存储型漏洞必须执行POST后GET闭环验证",
    "探测返回空/无变化时，在切换探测之前先尝试同一探测的URL编码、双重编码和Unicode变体"
  ],
  "evidence_required": [
    "baseline",
    "boundary_result",
    "type_result",
    "error_handling"
  ],
  "negative_sufficiency": {
    "min_vectors": 3,
    "min_response_count": 2,
    "required_evidence_types": [
      "baseline",
      "boundary_result",
      "type_result"
    ]
  },
  "positive_depth_floor": {
    "min_depth": 2,
    "min_vectors": 3,
    "note": "注入：≥3 探测向量家族（语法/布尔/时间/错误），达 depth_score 2 才许 proof_ready"
  }
}
