{
  "id": "file-upload-risk",
  "title": "文件上传风险",
  "description": "覆盖上传、文件名、分类、存储位置、访问路径、内容处理和权限边界。",
  "match": {
    "vuln_classes": ["文件读取/穿越", "XSS", "命令执行/RCE"],
    "endpoints": ["upload", "file", "avatar", "image", "media", "attachment"],
    "params": ["filename", "file", "category", "dir", "folder", "module", "type", "path", "content_type", "extension", "url", "name", "newname", "save_name", "max_size", "size_limit", "width", "height", "callback", "return_url", "redirect", "title", "description", "alt", "tag"],
    "keywords": ["upload", "download", "preview", "image", "avatar", "attachment"]
  },
  "dimensions": [
    "文件类型、大小、存储位置是否由服务端可信策略决定",
    "文件名、分类、访问路径是否与用户输入解耦",
    "上传后访问权限是否与对象归属一致",
    "预览、转换、下载链路是否复用同一权限边界"
  ],
  "false_negative_rules": [
    "只验证上传成功不能证明风险闭合",
    "只看文件扩展名不能证明内容处理安全",
    "只测上传接口不能证明预览和下载链路闭合"
  ],
  "evidence_required": [
    "upload_response",
    "stored_metadata",
    "access_url",
    "permission_check"
  ],
  "negative_sufficiency": {
    "min_vectors": 4,
    "min_response_count": 2,
    "required_evidence_types": ["upload_response", "stored_metadata", "access_url"]
  },
  "positive_depth_floor": {
    "min_depth": 2,
    "min_vectors": 3,
    "note": "文件上传：≥3 向量（类型/扩展名/路径/内容），达 depth_score 2 才许 proof_ready"
  }
}
