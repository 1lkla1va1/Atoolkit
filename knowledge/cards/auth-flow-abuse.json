{
  "id": "auth-flow-abuse",
  "title": "认证流程滥用",
  "description": "覆盖注册、登录、重置、验证码、会话、令牌、管理入口等认证流程风险。",
  "match": {
    "vuln_classes": ["认证绕过/枚举", "未授权访问"],
    "endpoints": ["register", "login", "reset-password", "password", "captcha", "sms", "verify-code", "change-audit", "admin", "token", "session", "sub-login", "role"],
    "keywords": ["register", "login", "password", "captcha", "sms", "token", "session", "admin"]
  },
  "dimensions": [
    "不同认证状态下的可达性差异",
    "验证码、短信、重置、换绑流程的状态绑定",
    "登录失败、注册、重置中的用户枚举信号",
    "会话、令牌、角色切换后的权限一致性"
  ],
  "false_negative_rules": [
    "只用已登录身份访问不能证明未授权闭合",
    "只测成功路径不能证明重置和验证码流程闭合",
    "只比较页面文案不能证明后端权限一致"
  ],
  "evidence_required": [
    "anonymous_baseline",
    "authenticated_baseline",
    "state_transition",
    "role_comparison"
  ],
  "negative_sufficiency": {
    "min_vectors": 4,
    "min_response_count": 2,
    "required_evidence_types": ["anonymous_baseline", "authenticated_baseline"],
    "min_identities": 2
  },
  "positive_depth_floor": {
    "min_depth": 2,
    "min_vectors": 3,
    "min_roles": 2,
    "note": "认证流程滥用：≥2 角色对比 + ≥3 独立向量，达 depth_score 2 才许 proof_ready"
  }
}
